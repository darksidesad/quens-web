---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChicaProfilePage from '../../components/ChicaProfilePage';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';

export function getStaticPaths() {
  try {
    const dataPath = join(process.cwd(), '../../data/content.json');
    const content = JSON.parse(readFileSync(dataPath, 'utf-8'));
    return content.chicas.map((c: { slug: string }) => ({
      params: { slug: c.slug },
    }));
  } catch {
    return [{ params: { slug: 'sofia' } }, { params: { slug: 'valentina' } }];
  }
}

const { slug } = Astro.params;
const nombre = (slug ?? '')
  .split('-')
  .map((p) => p.charAt(0).toUpperCase() + p.slice(1))
  .join(' ');
---

<BaseLayout
  title={`${nombre} | Quenns Spa`}
  description={`Conoce a ${nombre}, especialista en masajes y terapias de bienestar en Quenns Spa. Reserva tu cita por WhatsApp.`}
>
  <ChicaProfilePage slug={slug!} client:load />
</BaseLayout>
